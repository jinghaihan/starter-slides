    "eslint": "catalog:lint",
    "lint-staged": "catalog:lint",
    "@slidev/cli": "catalog:slides",
    "@slidev/client": "catalog:slides",
    "@slidev/theme-default": "catalog:slides",
    "slidev-workspace": "catalog:slides",
    "vitest": "catalog:test",
